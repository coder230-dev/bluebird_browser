{
  "appId": "com.bluebird_browser.browser",
  "name": "bluebird_browser",
  "displayName": "Browser",
  "productName": "Bluebird Browser",
  "publisher": "Bluebird IPE",
  "repository": {
    "type": "git",
    "url": "https://github.com/coder230-dev/bluebird_browser.git"
  },
  "version": "2.0.0",
  "description": "",
  "main": "main.js",
  "build": {
    "directories": {
      "buildResources": "images"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "coder230-dev",
        "repo": "bluebird_browser",
        "private": false
      }
    ],
    "mac": {
      "icon": "icon.png",
      "extendInfo": {
        "CFBundleIdentifier": "com.bluebird_browser.browser",
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "Bluebird Browser",
            "CFBundleURLSchemes": [
              "http",
              "https"
            ]
          }
        ]
      }
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "linux": {
      "icon": "icon.png"
    }
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:mac": "electron-forge make --platform=darwin --arch=x64",
    "build:win": "electron-builder --win",
    "make:linux": "electron-forge make --platform=linux --arch=x64",
    "make:all": "electron-forge make --arch=x64"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron-context-menu": "^4.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9"
  }
}
